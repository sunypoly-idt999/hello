@article{santosPDFRAGReadyEvaluating2026,
  title = {From PDF to RAG-Ready: Evaluating Document Conversion Frameworks for Domain-Specific Question Answering},
  shorttitle = {From PDF to RAG-Ready},
  author = {dos Santos, José Guilherme Marques and Yang, Ricardo and Pereira, Rui Humberto and Sousa, Alexandre and Faria, Brígida Mónica and Cardoso, Henrique Lopes and Duarte, José and Reis, José Luís and Reis, Luís Paulo and Pimenta, Pedro and dos Santos, José Paulo Marques},
  year = 2026,
